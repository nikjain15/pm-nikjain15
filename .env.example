# ---------------------------------------------------------------------------
# PUBLIC — safe in the browser
# ---------------------------------------------------------------------------
# Firebase web config — Project settings → General → Your apps → Web app.
# These are public by design: they ship in the client bundle and are not secrets.
# Access is controlled by Firestore security rules (see firestore.rules), not by hiding these.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---------------------------------------------------------------------------
# SECRET — server-side only. NEVER prefix these with NEXT_PUBLIC_.
# ---------------------------------------------------------------------------
# Anything named NEXT_PUBLIC_* is inlined into the JavaScript bundle and served to
# every visitor. The keys below must only ever be read from route handlers.
#
# Anthropic API key — writes the narratives ("Cracked the auth flow after a
# two-hour fight..."). Get one at console.anthropic.com/settings/keys.
#
# NOTE: a chat subscription is NOT API credit — they are separate products.
# This key needs its own credits: console.anthropic.com/settings/billing.
#
# Cost: cache narrations by commit SHA range and skip members with no new commits.
# Uncached this is ~$12/day (~$524 over the pilot); cached it's ~$0.65/day.
# The cache is a budget requirement, not an optimisation. See TESTING.md.
ANTHROPIC_API_KEY=

# GitHub token for reading the PUBLIC cohort repo when nobody is signed in
# (the landing page pre-index). Unauthenticated GitHub is 60 req/hr, which is not
# enough for 65 members; a token raises it to 5,000/hr. Needs NO scopes — public
# data only. Create at github.com/settings/tokens (fine-grained, read-only, public).
GITHUB_TOKEN=

# Feature flag: index all 65 members from the public cohort repo before they sign up.
# Behind a flag because it's pending Roger's answer on the IRB/peer-indexing question
# (see CHECKLIST.md open questions). If the answer is no, set this to false — one flag,
# not a rewrite.
PEER_INDEX_ENABLED=true
